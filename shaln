#!/usr/bin/env bash
#
# shaln — sharded alignment as a duckdb + bash binary.
#
# A thin CLI over the duckdb-miint extension's sharded alignment table functions.
# Its only runtime dependencies are `duckdb` (>= 1.5.4) and bash.
#
# Subcommands:
#   index     Build a sharded alignment bundle from references + a shard map
#   align     Align reads against a sharded bundle
#   version   Print the shaln version
#   help      Show usage
#
# Environment:
#   SHALN_DUCKDB           Path to the duckdb binary (overrides discovery)
#   SHALN_EXTENSION_PATH   Path to a local miint extension (loaded unsigned)
#
# The script is safe to `source` (for testing): it defines functions and only
# runs `main` when executed directly.

# Resolve our own location (used for the vendored-duckdb discovery fallback).
SHALN_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SHALN_VERSION="0.1.0"
SHALN_MIN_DUCKDB="1.5.4"

# ---------------------------------------------------------------------------
# Diagnostics
# ---------------------------------------------------------------------------

# shaln_err <message...> — print an error to stderr (no exit; for return-based flows).
shaln_err() {
  printf 'shaln: error: %s\n' "$*" >&2
}

# shaln_die <message...> — print an error to stderr and exit 1 (top-level paths only).
shaln_die() {
  shaln_err "$@"
  exit 1
}

# shaln_arg_error <message...> — usage/argument error: stderr + exit 2.
shaln_arg_error() {
  shaln_err "$@"
  exit 2
}

# shaln_log <message...> — a timestamped progress milestone to stderr, emitted
# only under --verbose (SHALN_VERBOSE). Layer 1 of the verbose output.
shaln_log() {
  [[ -n "${SHALN_VERBOSE:-}" ]] || return 0
  printf '[%s] shaln: %s\n' "$(date '+%H:%M:%S')" "$*" >&2
}

# ---------------------------------------------------------------------------
# DuckDB discovery + version gate
# ---------------------------------------------------------------------------

# shaln_resolve_duckdb — print the duckdb binary path on stdout.
# Order: $SHALN_DUCKDB, vendored $SHALN_HOME/duckdb, `duckdb` on PATH.
# On failure: error to stderr, return 1. (Uses only builtins so it is robust
# under a stripped PATH.)
shaln_resolve_duckdb() {
  if [[ -n "${SHALN_DUCKDB:-}" ]]; then
    if [[ ! -x "$SHALN_DUCKDB" ]]; then
      shaln_err "SHALN_DUCKDB is set to '$SHALN_DUCKDB' but it is not an executable file"
      return 1
    fi
    printf '%s\n' "$SHALN_DUCKDB"
    return 0
  fi
  if [[ -x "$SHALN_HOME/duckdb" ]]; then
    printf '%s\n' "$SHALN_HOME/duckdb"
    return 0
  fi
  local found
  found="$(command -v duckdb 2>/dev/null || true)"
  if [[ -n "$found" ]]; then
    printf '%s\n' "$found"
    return 0
  fi
  shaln_err "could not find a duckdb binary. Set SHALN_DUCKDB, vendor one at \$SHALN_HOME/duckdb, or install duckdb (>= $SHALN_MIN_DUCKDB) on PATH"
  return 1
}

# shaln_duckdb_version <bin> — print the dotted version (e.g. 1.5.4) on stdout.
# DuckDB's `--version` prints e.g. "v1.5.4 (Variegata) 08e34c447b".
shaln_duckdb_version() {
  local bin="$1" raw
  raw="$("$bin" --version 2>/dev/null)" || return 1
  raw="${raw#v}"   # strip a leading 'v'
  raw="${raw%% *}" # keep the first whitespace-delimited token
  printf '%s\n' "$raw"
}

# shaln_version_ge <a> <b> — return 0 iff dotted version a >= b. Pure; no I/O.
shaln_version_ge() {
  local IFS=.
  local -a a b
  # Word-splitting on '.' is the point here (split a dotted version into parts).
  # shellcheck disable=SC2206
  a=($1)
  # shellcheck disable=SC2206
  b=($2)
  local i av bv
  for ((i = 0; i < ${#b[@]}; i++)); do
    av="${a[i]:-0}"
    bv="${b[i]:-0}"
    if ((10#$av > 10#$bv)); then return 0; fi
    if ((10#$av < 10#$bv)); then return 1; fi
  done
  return 0
}

# shaln_require_duckdb — resolve duckdb, enforce the version gate, print its path.
# On failure: error to stderr, return 1.
shaln_require_duckdb() {
  local bin ver
  bin="$(shaln_resolve_duckdb)" || return 1
  ver="$(shaln_duckdb_version "$bin")"
  if [[ -z "$ver" ]]; then
    shaln_err "could not determine the duckdb version from '$bin --version'"
    return 1
  fi
  if ! shaln_version_ge "$ver" "$SHALN_MIN_DUCKDB"; then
    shaln_err "found duckdb $ver at '$bin', but shaln requires duckdb >= $SHALN_MIN_DUCKDB"
    return 1
  fi
  printf '%s\n' "$bin"
}

# shaln_run_sql <sql> — run a SQL script through the resolved duckdb. Prepends
# `.bail on` so the first error stops the script and exits nonzero (fail loud).
# Requires SHALN_DUCKDB_BIN + SHALN_DUCKDB_FLAGS to be set. Under --verbose the
# duckdb output (timed per-shard banners) streams live; otherwise it is captured
# and shown only on failure. Dies on any error. With SHALN_DUMP_SQL set, prints
# the assembled SQL to stdout and runs nothing (used to test the SQL shape).
shaln_run_sql() {
  if [[ -n "${SHALN_DUMP_SQL:-}" ]]; then printf '%s\n' "$1"; return 0; fi
  local sql=".bail on
$1"
  if [[ -n "${SHALN_VERBOSE:-}" ]]; then
    if ! printf '%s\n' "$sql" | "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch; then
      shaln_die "duckdb failed (see output above)"
    fi
  else
    local out
    if ! out="$(printf '%s\n' "$sql" | "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch 2>&1)"; then
      shaln_err "duckdb failed:"
      printf '%s\n' "$out" >&2
      exit 1
    fi
  fi
}

# ---------------------------------------------------------------------------
# Extension load preamble
# ---------------------------------------------------------------------------

# shaln_sql_quote <string> — print a single-quoted SQL string literal, doubling
# any embedded single quotes. (Uses a quote variable so the replacement is two
# literal quotes, not bash-escaped ones.)
shaln_sql_quote() {
  local q="'"
  local s="$1"
  s="${s//$q/$q$q}"
  printf "%s%s%s" "$q" "$s" "$q"
}

# shaln_extension_preamble [ext_path] — print the SQL that loads the miint
# extension. With no path (and no $SHALN_EXTENSION_PATH), install from the
# community repository; otherwise load the given local extension by path.
#
# NOTE: loading a local (unsigned) extension also requires launching duckdb with
# the -unsigned flag (see shaln_duckdb_flags) — `allow_unsigned_extensions` is a
# startup-only setting and cannot be changed with a SET statement once the
# database is running.
# $1 is optional (tests pass an explicit path; callers here rely on the env var).
# shellcheck disable=SC2120
shaln_extension_preamble() {
  local ext="${1:-${SHALN_EXTENSION_PATH:-}}"
  if [[ -n "$ext" ]]; then
    printf 'LOAD %s;\n' "$(shaln_sql_quote "$ext")"
  else
    printf 'INSTALL miint FROM community;\nLOAD miint;\n'
  fi
}

# shaln_duckdb_flags [ext_path] — print the extra duckdb CLI flags required by
# the chosen extension-load strategy. A local extension path needs `-unsigned`
# at startup; the community-install path needs nothing.
# $1 is optional (tests pass an explicit path; callers here rely on the env var).
# shellcheck disable=SC2120
shaln_duckdb_flags() {
  local ext="${1:-${SHALN_EXTENSION_PATH:-}}"
  if [[ -n "$ext" ]]; then
    printf '%s' '-unsigned'
  fi
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

shaln_usage() {
  cat <<EOF
shaln $SHALN_VERSION — sharded alignment over DuckDB + duckdb-miint

Usage:
  shaln <command> [options]

Commands:
  index     Build a sharded alignment bundle from references + a shard map
  align     Align reads against a sharded bundle
  version   Print the shaln version
  help      Show this help

Environment:
  SHALN_DUCKDB           Path to the duckdb binary (>= $SHALN_MIN_DUCKDB)
  SHALN_EXTENSION_PATH   Path to a local miint extension (loaded unsigned)

Run 'shaln <command> --help' for command-specific options.
EOF
}

shaln_cmd_version() {
  printf 'shaln %s\n' "$SHALN_VERSION"
}

# shaln_validate_int <flag-name> <value> — die (usage error) unless value is a
# positive integer (>= 1). Used for --chunk-size / --k / --w / --threads.
shaln_validate_int() {
  case "$2" in
  '' | *[!0-9]*) shaln_arg_error "shaln index: $1 must be a positive integer, got '$2'" ;;
  esac
  if ! ((10#$2 >= 1)); then
    shaln_arg_error "shaln index: $1 must be >= 1, got '$2'"
  fi
}

# shaln_index_usage — usage text for `shaln index`.
shaln_index_usage() {
  cat <<EOF
Usage: shaln index --references <fasta|parquet> --shard-map <tsv> -o <bundle> [options]

Build a sharded alignment bundle.

Required:
  --references PATH   Reference sequences: FASTA/FASTQ, or Parquet (read_fastx schema).
  --shard-map PATH    TSV (no header), 2 columns: <reference_id>\t<shard_name>.
                      Only references listed here are indexed; any reference in
                      --references that is absent from the shard-map is ignored.
  -o, --output DIR    Output bundle directory.

Options:
  --aligner NAME      'minimap2' (default) or 'bowtie2' (requires gpl-boundary).
  --chunk-size N      Reference chunk size for the rype routing index (default 100000).
  --preset STR        minimap2 preset (baked into the .mmi at index time).
  --k N               minimap2 k-mer size (index time).
  --w N               minimap2 minimizer window (index time).
  --eqx               minimap2: emit =/X CIGAR ops (index time).
  --threads N         bowtie2-build threads.
  --in-memory         Hold references in a RAM table instead of converting them to a
                      temp zstd Parquet (default streams them from disk per shard).
  --extension-path P  Load a local (unsigned) miint extension instead of the community build.
  --verbose           Timestamped progress to stderr.
  -h, --help          Show this help.
EOF
}

# shaln_read_shard_names <shard-map> — print the distinct shard names (column 2),
# after validating the TSV format and that every shard name is a safe path/SQL
# component. Errors to stderr + return 1 on a malformed map or unsafe name.
shaln_read_shard_names() {
  local map="$1" names
  # One pass: validate the 2-column format AND emit column 2. awk exits 1 on a
  # malformed row, which pipefail surfaces as a failure of the substitution.
  if ! names="$(awk -F'\t' '
      /^[[:space:]]*$/ { next }
      NF != 2 || $1 == "" || $2 == "" { exit 1 }
      { print $2 }
    ' "$map" | sort -u)"; then
    shaln_err "shaln index: shard-map '$map' must be a 2-column TSV: <reference_id>\\t<shard_name>"
    return 1
  fi
  local s
  while IFS= read -r s; do
    [[ -z "$s" ]] && continue
    case "$s" in
    . | ..) shaln_err "shaln index: invalid shard name '$s'"; return 1 ;;
    *[!A-Za-z0-9._-]*)
      shaln_err "shaln index: shard name '$s' has unsafe characters (allowed: A-Z a-z 0-9 . _ -)"
      return 1
      ;;
    esac
  done <<EOF
$names
EOF
  printf '%s\n' "$names"
}

# shaln_minimap2_named_params <preset> <k> <w> <eqx> — emit the trailing named
# parameters for save_minimap2_index (each only when set). Leading ", " included.
shaln_minimap2_named_params() {
  local preset="$1" k="$2" w="$3" eqx="$4" out=""
  [[ -n "$preset" ]] && out="$out, preset := $(shaln_sql_quote "$preset")"
  [[ -n "$k" ]] && out="$out, k := $k"
  [[ -n "$w" ]] && out="$out, w := $w"
  [[ -n "$eqx" ]] && out="$out, eqx := true"
  printf '%s' "$out"
}

# shaln_bowtie2_named_params <threads> — trailing named params for save_bowtie2_index.
shaln_bowtie2_named_params() {
  [[ -n "$1" ]] && printf ', threads := %s' "$1"
}

# shaln_bowtie2_available — return 0 iff a FRESH duckdb process reports
# bowtie2_available() = true. A fresh process every call is deliberate:
# bowtie2_available() is memoized within a duckdb process, so the post-install
# re-check below would see the stale "false" if it reused a connection.
shaln_bowtie2_available() {
  local out
  out="$(printf '%s\nSELECT bowtie2_available();\n' "$(shaln_extension_preamble)" \
    | "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch -noheader -list 2>/dev/null)"
  [[ "$out" == *true* ]]
}

# shaln_install_gpl_boundary — attempt the one-shot auto-install and print the
# install function's own human-readable message (stdout+stderr merged). Idempotent
# in the extension (no-ops if gpl-boundary is already present).
shaln_install_gpl_boundary() {
  printf '%s\nSELECT (install_gpl_boundary()).message;\n' "$(shaln_extension_preamble)" \
    | "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch -noheader -list 2>&1
}

# shaln_require_bowtie2 <subcmd> — ensure the bowtie2 aligner is usable. If it is
# not, attempt to install gpl-boundary automatically, then re-check in a FRESH
# duckdb process (see shaln_bowtie2_available). Only if it is still unavailable do
# we die — with a plain-language message that does not assume the reader knows
# what DuckDB is: it explains what gpl-boundary is, that an auto-install was
# attempted, the real prerequisites (network + curl), and a no-install fallback.
# <subcmd> ('index'/'align') prefixes the messages so they name the right command.
shaln_require_bowtie2() {
  local subcmd="$1"
  shaln_bowtie2_available && return 0

  printf 'shaln %s: bowtie2 is unavailable; attempting a one-time install of gpl-boundary (needs network access + curl)...\n' "$subcmd" >&2
  # `|| true`: never let a nonzero duckdb exit here (e.g. a broken extension)
  # trip `set -e` and skip the fresh-process re-check + friendly message below.
  local msg
  msg="$(shaln_install_gpl_boundary)" || true
  [[ -n "$msg" ]] && printf 'shaln %s: %s\n' "$subcmd" "$msg" >&2

  shaln_bowtie2_available && return 0

  shaln_die "shaln $subcmd: the bowtie2 aligner is unavailable, and shaln could not install it automatically.

shaln runs bowtie2 through a helper component called \"gpl-boundary\" that it
downloads on first use. The automatic install just attempted did not succeed.

This almost always means one of:
  - this machine has no network access, or
  - the 'curl' command is not installed (gpl-boundary is fetched with curl).

To use bowtie2: make sure this machine can reach the internet and has 'curl'
installed, then run shaln again — it retries the install automatically. If you
do not need bowtie2 specifically, re-run with the default '--aligner minimap2',
which needs no extra download."
}

# shaln_index_build_sql <refs_reader> <shard_map> <output> <aligner> <chunk_size>
#                       <preset> <k> <w> <eqx> <threads> <shards> <refs_pq>
# Emit the full SQL script (preamble + build) to stdout. References are converted
# ONCE to a zstd parquet at <refs_pq> (feature_idx baked in, stable across the
# per-shard re-scans) and exposed as a VIEW; the derived relations
# (__shaln_mapped/_chunks/_mapping) are VIEWs over it, so the index build re-scans
# the reference parquet from disk per shard rather than holding all references in
# RAM. If <refs_pq> is empty, references are held in a RAM TABLE instead
# (--in-memory). The shard-map / check / sink relations stay tiny TABLEs.
shaln_index_build_sql() {
  local refs_reader="$1" shard_map="$2" output="$3" aligner="$4" chunk_size="$5"
  local preset="$6" mm_k="$7" mm_w="$8" eqx="$9" threads="${10}" shards="${11}" refs_pq="${12:-}"
  local vp=""
  [[ -n "${SHALN_VERBOSE:-}" ]] && vp=1

  # Value-producing queries are wrapped in CREATE TABLE/VIEW so their results never
  # hit stdout — shaln detects failure via `.bail on` exit codes, not output.
  # Verbose progress comes from the `.print` banners below.
  printf '%s\n' "$(shaln_extension_preamble)"

  # References -> a zstd parquet once (feature_idx baked), exposed as a view; or a
  # RAM table under --in-memory. Either way __shaln_refs has (feature_idx, read_id,
  # sequence1) and feature_idx is stable for the rype mapping.
  if [[ -n "$refs_pq" ]]; then
    printf "COPY (SELECT row_number() OVER (ORDER BY read_id)::BIGINT AS feature_idx, read_id, sequence1 FROM %s) TO %s (FORMAT PARQUET, COMPRESSION 'zstd');\n" "$refs_reader" "$(shaln_sql_quote "$refs_pq")"
    printf "CREATE OR REPLACE VIEW __shaln_refs AS SELECT * FROM read_parquet(%s);\n" "$(shaln_sql_quote "$refs_pq")"
  else
    printf "CREATE OR REPLACE TABLE __shaln_refs AS SELECT row_number() OVER (ORDER BY read_id)::BIGINT AS feature_idx, read_id, sequence1 FROM %s;\n" "$refs_reader"
  fi
  printf "CREATE OR REPLACE TABLE __shaln_map AS SELECT * FROM read_csv(%s, delim='\\t', header=false, columns={'reference_id':'VARCHAR','shard_name':'VARCHAR'});\n" "$(shaln_sql_quote "$shard_map")"
  # Fail loud if a shard-map reference_id is absent from the references.
  printf "CREATE OR REPLACE TABLE __shaln_check AS SELECT CASE WHEN count(*) > 0 THEN error('shaln index: shard-map reference(s) not found in --references: ' || string_agg(DISTINCT reference_id, ', ')) ELSE 0 END AS ok FROM (SELECT m.reference_id FROM __shaln_map m LEFT JOIN __shaln_refs r ON m.reference_id = r.read_id WHERE r.read_id IS NULL) _v;\n"
  printf "CREATE OR REPLACE VIEW __shaln_mapped AS SELECT f.feature_idx, f.read_id, f.sequence1, m.shard_name FROM __shaln_refs f JOIN __shaln_map m ON f.read_id = m.reference_id;\n"

  local n i=0 s cnt
  n="$(printf '%s\n' "$shards" | grep -c .)"
  while IFS= read -r s; do
    [[ -z "$s" ]] && continue
    i=$((i + 1))
    if [[ -n "$vp" ]]; then
      # Per-shard reference count = shard-map rows for this shard (validation
      # above guarantees every shard-map reference exists in --references).
      cnt="$(awk -F'\t' -v s="$s" '$2 == s {n++} END {print n + 0}' "$shard_map")"
      printf ".print '[shard %d/%d] %s (%s, %s reference(s))'\n" "$i" "$n" "$s" "$aligner" "$cnt"
    fi
    printf "CREATE OR REPLACE VIEW __shaln_subj AS SELECT read_id, sequence1 FROM __shaln_mapped WHERE shard_name = %s;\n" "$(shaln_sql_quote "$s")"
    if [[ "$aligner" == "minimap2" ]]; then
      printf "CREATE OR REPLACE TABLE __shaln_sink AS SELECT success FROM save_minimap2_index('__shaln_subj', %s%s);\n" \
        "$(shaln_sql_quote "$output/$s.mmi")" "$(shaln_minimap2_named_params "$preset" "$mm_k" "$mm_w" "$eqx")"
    else
      printf "CREATE OR REPLACE TABLE __shaln_sink AS SELECT success FROM save_bowtie2_index('__shaln_subj', %s%s);\n" \
        "$(shaln_sql_quote "$output/$s/index")" "$(shaln_bowtie2_named_params "$threads")"
    fi
  done <<EOF
$shards
EOF

  [[ -n "$vp" ]] && printf ".print 'building rype routing index'\n"
  printf "CREATE OR REPLACE VIEW __shaln_chunks AS WITH e AS (SELECT feature_idx, UNNEST(sequence_split(sequence1, %s)) AS c FROM __shaln_mapped) SELECT feature_idx, c.chunk_index AS chunk_index, c.chunk_data AS chunk_data FROM e;\n" "$chunk_size"
  printf "CREATE OR REPLACE VIEW __shaln_mapping AS SELECT feature_idx, shard_name AS bucket_name FROM __shaln_mapped;\n"
  printf "CREATE OR REPLACE TABLE __shaln_sink AS SELECT status FROM rype_index_create('__shaln_chunks', %s, mapping_table := '__shaln_mapping', k := 16, w := 8);\n" "$(shaln_sql_quote "$output/rype.ryxdi")"

  [[ -n "$vp" ]] && printf ".print 'writing lengths.parquet'\n"
  printf "COPY (SELECT read_id AS name, length(sequence1)::BIGINT AS length FROM __shaln_refs ORDER BY name) TO %s (FORMAT PARQUET);\n" "$(shaln_sql_quote "$output/lengths.parquet")"
}

# shaln_index_write_manifest <output> <aligner> <chunk_size> <shards>
shaln_index_write_manifest() {
  local output="$1" aligner="$2" chunk_size="$3" shards="$4"
  local man="$output/manifest.tsv" s
  {
    printf 'shaln_manifest_version\t1\n'
    printf 'aligner\t%s\n' "$aligner"
    printf 'rype\trype.ryxdi\n'
    printf 'lengths\tlengths.parquet\n'
    printf 'chunk_size\t%s\n' "$chunk_size"
    while IFS= read -r s; do
      [[ -z "$s" ]] && continue
      printf 'shard\t%s\n' "$s"
    done <<EOF
$shards
EOF
  } >"$man" || shaln_die "shaln index: could not write manifest '$man'"
}

shaln_cmd_index() {
  local references="" shard_map="" output="" aligner="minimap2"
  local chunk_size="100000" preset="" mm_k="" mm_w="" eqx="" threads="" ext_path="" in_memory=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --references) references="${2:-}"; shift 2 ;;
    --shard-map) shard_map="${2:-}"; shift 2 ;;
    -o | --output) output="${2:-}"; shift 2 ;;
    --aligner) aligner="${2:-}"; shift 2 ;;
    --chunk-size) chunk_size="${2:-}"; shift 2 ;;
    --preset) preset="${2:-}"; shift 2 ;;
    --k) mm_k="${2:-}"; shift 2 ;;
    --w) mm_w="${2:-}"; shift 2 ;;
    --eqx) eqx=1; shift ;;
    --threads) threads="${2:-}"; shift 2 ;;
    --in-memory) in_memory=1; shift ;;
    --extension-path) ext_path="${2:-}"; shift 2 ;;
    --verbose) SHALN_VERBOSE=1; shift ;;
    -h | --help) shaln_index_usage; return 0 ;;
    --) shift; break ;;
    -*) shaln_arg_error "shaln index: unknown option '$1'" ;;
    *) shaln_arg_error "shaln index: unexpected argument '$1'" ;;
    esac
  done

  # Required arguments.
  [[ -n "$references" ]] || shaln_arg_error "shaln index: --references is required"
  [[ -n "$shard_map" ]] || shaln_arg_error "shaln index: --shard-map is required"
  [[ -n "$output" ]] || shaln_arg_error "shaln index: -o/--output (bundle directory) is required"

  # Aligner must be known before we touch the filesystem or duckdb.
  case "$aligner" in
  minimap2 | bowtie2) ;;
  *) shaln_arg_error "shaln index: --aligner must be 'minimap2' or 'bowtie2', got '$aligner'" ;;
  esac

  # Numeric knobs.
  shaln_validate_int "--chunk-size" "$chunk_size"
  [[ -n "$mm_k" ]] && shaln_validate_int "--k" "$mm_k"
  [[ -n "$mm_w" ]] && shaln_validate_int "--w" "$mm_w"
  [[ -n "$threads" ]] && shaln_validate_int "--threads" "$threads"

  # Inputs must exist.
  [[ -f "$references" ]] || shaln_arg_error "shaln index: references file not found: $references"
  [[ -f "$shard_map" ]] || shaln_arg_error "shaln index: shard-map file not found: $shard_map"

  [[ -n "$ext_path" ]] && SHALN_EXTENSION_PATH="$ext_path"

  SHALN_DUCKDB_BIN="$(shaln_require_duckdb)" || exit 1
  SHALN_DUCKDB_FLAGS="$(shaln_duckdb_flags)"

  [[ "$aligner" == "bowtie2" ]] && shaln_require_bowtie2 index

  local shards
  shards="$(shaln_read_shard_names "$shard_map")" || exit 1
  [[ -n "$shards" ]] || shaln_die "shaln index: shard-map '$shard_map' lists no shards"
  local n_shards
  n_shards="$(printf '%s\n' "$shards" | grep -c .)"

  shaln_log "indexing into bundle '$output' (aligner=$aligner, $n_shards shard(s))"
  mkdir -p "$output" || shaln_die "shaln index: could not create bundle directory '$output'"

  local refs_reader
  case "$references" in
  *.parquet | *.pq) refs_reader="read_parquet($(shaln_sql_quote "$references"))" ;;
  *) refs_reader="read_fastx($(shaln_sql_quote "$references"))" ;;
  esac

  # Default: convert references to a temp zstd parquet (re-scanned per shard from
  # disk, never held whole in RAM), auto-cleaned on exit. --in-memory holds them
  # in a RAM table instead (fast path for reference sets that fit).
  local refs_pq=""
  if [[ -z "$in_memory" ]]; then
    refs_pq="$(mktemp "${TMPDIR:-/tmp}/shaln-refs.XXXXXX")"
    shaln_tmp_register "$refs_pq"
  fi

  shaln_log "building per-shard indexes + rype routing index"
  shaln_run_sql "$(shaln_index_build_sql "$refs_reader" "$shard_map" "$output" "$aligner" "$chunk_size" "$preset" "$mm_k" "$mm_w" "$eqx" "$threads" "$shards" "$refs_pq")"

  shaln_index_write_manifest "$output" "$aligner" "$chunk_size" "$shards"
  shaln_log "done: bundle ready at '$output'"
}

# ---------------------------------------------------------------------------
# Reads input layer (shared by `shaln align`)
# ---------------------------------------------------------------------------

# shaln_normalize_path <path> — map '-' to /dev/stdin; leave everything else.
shaln_normalize_path() {
  if [[ "$1" == "-" ]]; then printf '/dev/stdin'; else printf '%s' "$1"; fi
}

# shaln_parse_reads_input <args...> — pick exactly one reads input mode from the
# input flags and set globals READS_MODE / READS_P1 / READS_P2. Any argument
# that is not an input flag (or its value) is collected into the SHALN_REST array
# for the caller (`shaln align`) to continue parsing. Errors to stderr + return 2.
#
# Modes: single (--fasta/--fastq, read_fastx auto-detects), paired (-1/-2),
# interleaved (--interleaved), parquet (--parquet), arrow (--arrow, Arrow IPC).
# A path of '-' means stdin.
shaln_parse_reads_input() {
  READS_MODE=""
  READS_P1=""
  READS_P2=""
  SHALN_REST=()
  local fastx="" parquet="" arrow="" il="" r1="" r2=""
  local have_fastx="" have_parquet="" have_arrow="" have_il="" have_paired=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --fasta | --fastq)
      [[ $# -ge 2 ]] || { shaln_err "shaln align: '$1' requires a path"; return 2; }
      fastx="$2"; have_fastx=1; shift 2 ;;
    --parquet)
      [[ $# -ge 2 ]] || { shaln_err "shaln align: '$1' requires a path"; return 2; }
      parquet="$2"; have_parquet=1; shift 2 ;;
    --arrow)
      [[ $# -ge 2 ]] || { shaln_err "shaln align: '$1' requires a path ('-' for stdin)"; return 2; }
      arrow="$2"; have_arrow=1; shift 2 ;;
    --interleaved)
      [[ $# -ge 2 ]] || { shaln_err "shaln align: '$1' requires a path"; return 2; }
      il="$2"; have_il=1; shift 2 ;;
    -1)
      [[ $# -ge 2 ]] || { shaln_err "shaln align: '-1' requires a path"; return 2; }
      r1="$2"; have_paired=1; shift 2 ;;
    -2)
      [[ $# -ge 2 ]] || { shaln_err "shaln align: '-2' requires a path"; return 2; }
      r2="$2"; have_paired=1; shift 2 ;;
    *)
      SHALN_REST+=("$1"); shift ;;
    esac
  done

  local n=0
  [[ -n "$have_fastx" ]] && n=$((n + 1))
  [[ -n "$have_parquet" ]] && n=$((n + 1))
  [[ -n "$have_arrow" ]] && n=$((n + 1))
  [[ -n "$have_il" ]] && n=$((n + 1))
  [[ -n "$have_paired" ]] && n=$((n + 1))
  if [[ "$n" -eq 0 ]]; then
    shaln_err "shaln align: no reads input (use --fasta/--fastq/--parquet/--arrow/--interleaved or -1/-2)"
    return 2
  fi
  if [[ "$n" -gt 1 ]]; then
    shaln_err "shaln align: choose exactly one reads input mode"
    return 2
  fi

  if [[ -n "$have_paired" ]]; then
    [[ -n "$r1" && -n "$r2" ]] || { shaln_err "shaln align: paired input requires both -1 and -2"; return 2; }
    READS_MODE="paired"
    READS_P1="$(shaln_normalize_path "$r1")"
    READS_P2="$(shaln_normalize_path "$r2")"
  elif [[ -n "$have_fastx" ]]; then
    READS_MODE="single"
    READS_P1="$(shaln_normalize_path "$fastx")"
  elif [[ -n "$have_parquet" ]]; then
    READS_MODE="parquet"
    READS_P1="$(shaln_normalize_path "$parquet")"
  elif [[ -n "$have_arrow" ]]; then
    READS_MODE="arrow"
    READS_P1="$(shaln_normalize_path "$arrow")"
  else
    READS_MODE="interleaved"
    READS_P1="$(shaln_normalize_path "$il")"
  fi
  return 0
}

# shaln_reads_relation <mode> <p1> [p2] — emit a parenthesized SQL relation that
# yields the normalized read schema
#   (sequence_index BIGINT, read_id, sequence1, sequence2, qual1, qual2)
# for the given mode. `sequence_index` is the cheap BIGINT join key used for
# routing + alignment (joins on it beat joins on the VARCHAR read_id). For the
# read_fastx-backed modes it is the reader's own per-record index (unique for a
# single source; assigned during the streaming scan, no buffering). For arrow
# (which carries no sequence_index) it is minted with row_number() OVER (), which
# DuckDB evaluates with a STREAMING_WINDOW operator — constant memory, so this is
# safe for larger-than-RAM inputs. Single-scan throughout, so it is safe over a
# non-seekable stdin. Arrow requires the arrow extension to be loaded first.
shaln_reads_relation() {
  local mode="$1" p1="$2" p2="${3:-}"
  case "$mode" in
  single)
    printf '(SELECT sequence_index, read_id, sequence1, sequence2, qual1, qual2 FROM read_fastx(%s))' \
      "$(shaln_sql_quote "$p1")" ;;
  paired)
    printf '(SELECT sequence_index, read_id, sequence1, sequence2, qual1, qual2 FROM read_fastx(%s, sequence2 := %s))' \
      "$(shaln_sql_quote "$p1")" "$(shaln_sql_quote "$p2")" ;;
  interleaved)
    # Native de-interleave (one stream -> paired rows), one sequence_index per pair.
    printf '(SELECT sequence_index, read_id, sequence1, sequence2, qual1, qual2 FROM read_fastx(%s, interleaved := true))' \
      "$(shaln_sql_quote "$p1")" ;;
  parquet)
    printf '(SELECT sequence_index, read_id, sequence1, sequence2, qual1, qual2 FROM read_parquet(%s))' \
      "$(shaln_sql_quote "$p1")" ;;
  arrow)
    printf "(SELECT row_number() OVER ()::BIGINT AS sequence_index, read_id, sequence1, sequence2, qual1, qual2 FROM read_arrow(%s))" \
      "$(shaln_sql_quote "$p1")" ;;
  *)
    shaln_err "internal: unknown reads mode '$mode'"
    return 1 ;;
  esac
}

# Temp-file lifecycle. shaln converts non-parquet reads (and references) to a
# zstd parquet in TMPDIR for streaming + cheap random access. Those scratch files
# are removed on exit UNLESS the user asked to persist them (--reads-cache /
# --save-routing / --refs-cache). Only paths registered here are ever rm'd — the
# trap never touches anything shaln did not itself create with mktemp.
SHALN_TMPFILES=()
shaln_tmp_cleanup() {
  [[ ${#SHALN_TMPFILES[@]} -gt 0 ]] || return 0
  local f
  for f in "${SHALN_TMPFILES[@]}"; do
    [[ -n "$f" && -e "$f" ]] && rm -f "$f"
  done
}
# shaln_tmp_register <path> — track <path> for removal on exit.
shaln_tmp_register() {
  SHALN_TMPFILES+=("$1")
  trap shaln_tmp_cleanup EXIT
}

# shaln_verify_reads_parquet <path> — ensure a --parquet reads file carries a
# UNIQUE BIGINT `sequence_index` column (the routing + name-recovery key). Dies
# with an actionable message otherwise. Two cheap probes: a DESCRIBE (no scan) for
# the column + type, then one aggregate for uniqueness.
shaln_verify_reads_parquet() {
  local path="$1" pq has uniq
  pq="$(shaln_sql_quote "$path")"
  has="$(printf "%s\nSELECT count(*) FROM (DESCRIBE SELECT * FROM read_parquet(%s)) WHERE column_name = 'sequence_index' AND column_type = 'BIGINT';\n" \
    "$(shaln_extension_preamble)" "$pq" | "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch -noheader -list 2>/dev/null)"
  if [[ "$has" != "1" ]]; then
    shaln_die "shaln align: --parquet reads must have a BIGINT 'sequence_index' column (shaln routes and recovers read names by it). Produce the parquet from a single read_fastx source (which assigns sequence_index), or use a non-parquet input, or --in-memory."
  fi
  uniq="$(printf "%s\nSELECT count(*) = count(DISTINCT sequence_index) FROM read_parquet(%s);\n" \
    "$(shaln_extension_preamble)" "$pq" | "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch -noheader -list 2>/dev/null)"
  if [[ "$uniq" != "true" ]]; then
    shaln_die "shaln align: --parquet reads 'sequence_index' must be UNIQUE per read (it keys routing + name recovery). A multi-file/UNION'd parquet can repeat it — re-export from a single read_fastx source, or use --in-memory."
  fi
}

# shaln_run_sql_stream <sql> — run a SQL script through duckdb, letting stdout
# (the output stream, e.g. SAM/BAM/Arrow to /dev/stdout) and stderr (progress +
# errors) flow through to shaln's own streams. Prepends `.bail on`; dies on error.
# With SHALN_DUMP_SQL set, prints the assembled SQL to stdout and runs nothing.
#
# The SQL is passed via a temp file (-f), NOT piped on stdin: shaln's own stdin
# must stay free for reads input ('--fastq -' / '--arrow -'), which the SQL reads
# as '/dev/stdin'. Piping the SQL on stdin would consume that data stream first
# (duckdb reads the whole script to EOF before executing). The temp file is one of
# shaln's own scratch files, removed on exit.
shaln_run_sql_stream() {
  if [[ -n "${SHALN_DUMP_SQL:-}" ]]; then printf '%s\n' "$1"; return 0; fi
  local sqlfile
  sqlfile="$(mktemp "${TMPDIR:-/tmp}/shaln-sql.XXXXXX")"
  shaln_tmp_register "$sqlfile"
  printf '.bail on\n%s\n' "$1" >"$sqlfile"
  if ! "$SHALN_DUCKDB_BIN" $SHALN_DUCKDB_FLAGS -batch -f "$sqlfile"; then
    shaln_die "shaln align: duckdb failed during alignment"
  fi
}

# shaln_validate_uint <flag> <value> — die (usage) unless value is a non-negative
# integer (allows 0, e.g. --max-secondary 0).
shaln_validate_uint() {
  case "$2" in
  '' | *[!0-9]*) shaln_arg_error "shaln align: $1 must be a non-negative integer, got '$2'" ;;
  esac
}

# shaln_validate_num <flag> <value> — die (usage) unless value is a simple
# decimal (rejects empty, non-numeric, multi-dot like '1.2.3', and a lone '.').
shaln_validate_num() {
  case "$2" in
  '' | . | *[!0-9.]* | *.*.*) shaln_arg_error "shaln align: $1 must be a number, got '$2'" ;;
  esac
}

# shaln_manifest_get <bundle> <key> — first value for <key> in manifest.tsv.
shaln_manifest_get() {
  awk -F'\t' -v k="$2" '$1 == k {print $2; exit}' "$1/manifest.tsv"
}

# shaln_manifest_shards <bundle> — the shard names recorded in the manifest.
shaln_manifest_shards() {
  awk -F'\t' '$1 == "shard" {print $2}' "$1/manifest.tsv"
}

# shaln_align_opt_table — the full alignment passthrough surface, one row per
# option: "<cli-flag> <sql-param> <kind> <scope>" where
#   kind  ∈ {string,uint,num,bool}  — drives validation + how the value is emitted
#   scope ∈ {both,minimap2,bowtie2} — which aligner the option is valid for
# This single table drives CLI parsing, validation, SQL generation, AND usage,
# so they can never drift (DRY). Every <sql-param> is a named parameter actually
# registered on align_minimap2_sharded / align_bowtie2_sharded — passing one the
# extension does not know would fail at query time, so this list is authoritative.
# Internal params (shard_directory/read_to_shard/debug/progress) and sharded
# `threads` (ignored) are deliberately omitted — shaln manages those itself.
shaln_align_opt_table() {
  cat <<'EOF'
--preset preset string both
--max-secondary max_secondary uint both
--max-threads-per-shard max_threads_per_shard uint both
--include-shard-name include_shard_name bool both
--mismatch-penalty mismatch_penalty uint both
--eqx eqx bool minimap2
--min-chain-coverage min_chain_coverage num minimap2
--match-score match_score uint minimap2
--gap-open gap_open uint minimap2
--gap-extend gap_extend uint minimap2
--gap-open2 gap_open2 uint minimap2
--gap-extend2 gap_extend2 uint minimap2
--bandwidth bandwidth uint minimap2
--zdrop zdrop uint minimap2
--zdrop-inv zdrop_inv uint minimap2
--min-chain-score min_chain_score uint minimap2
--min-count min_count uint minimap2
--max-gap max_gap uint minimap2
--min-dp-max min_dp_max uint minimap2
--pri-ratio pri_ratio num minimap2
--mask-level mask_level num minimap2
--local local bool bowtie2
--seed seed uint bowtie2
--trim5 trim5 uint bowtie2
--trim3 trim3 uint bowtie2
--match-bonus match_bonus uint bowtie2
--mismatch-penalty-min mismatch_penalty_min uint bowtie2
--n-penalty n_penalty uint bowtie2
--read-gap-open read_gap_open uint bowtie2
--read-gap-extend read_gap_extend uint bowtie2
--ref-gap-open ref_gap_open uint bowtie2
--ref-gap-extend ref_gap_extend uint bowtie2
--score-min score_min string bowtie2
--min-insert min_insert uint bowtie2
--max-insert max_insert uint bowtie2
--mate-orientation mate_orientation string bowtie2
--no-mixed no_mixed bool bowtie2
--no-discordant no_discordant bool bowtie2
--dovetail dovetail bool bowtie2
--no-contain no_contain bool bowtie2
--no-overlap no_overlap bool bowtie2
--nofw nofw bool bowtie2
--norc norc bool bowtie2
--seed-mismatches seed_mismatches uint bowtie2
--seed-length seed_length uint bowtie2
--max-dp-failures max_dp_failures uint bowtie2
--max-seed-rounds max_seed_rounds uint bowtie2
--report-all report_all bool bowtie2
--xeq xeq bool bowtie2
--rg-id rg_id string bowtie2
--ignore-quals ignore_quals bool bowtie2
--reorder reorder bool bowtie2
--no-exact-upfront no_exact_upfront bool bowtie2
--no-1mm-upfront no_1mm_upfront bool bowtie2
--deterministic-seeds deterministic_seeds bool bowtie2
