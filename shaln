}

# shaln_align_opt_lookup <flag> — if <flag> is a known passthrough option, set
# OPT_PARAM / OPT_KIND / OPT_SCOPE and return 0; otherwise return 1.
shaln_align_opt_lookup() {
  local f="$1" cf cp ck cs
  while read -r cf cp ck cs; do
    [[ -z "$cf" ]] && continue
    if [[ "$cf" == "$f" ]]; then
      OPT_PARAM="$cp"
      OPT_KIND="$ck"
      OPT_SCOPE="$cs"
      return 0
    fi
  done <<EOF
$(shaln_align_opt_table)
EOF
  return 1
}

# shaln_build_align_params <aligner> <passthrough-flag/value...> — validate the
# passthrough flags against the option table and print the trailing
# ", name := value" SQL (in the order given). Rejects (exit 2) a flag that does
# not apply to <aligner>, or a value that fails its kind's validation. Bool flags
# take no value and emit ":= true"; strings are SQL-quoted; uint/num are validated
# then emitted bare (safe to interpolate). Leading ", " included.
shaln_build_align_params() {
  local aligner="$1" out="" flag value
  shift
  while [[ $# -gt 0 ]]; do
    flag="$1"
    shaln_align_opt_lookup "$flag" || shaln_arg_error "shaln align: unknown option '$flag'"
    if [[ "$OPT_SCOPE" != "both" && "$OPT_SCOPE" != "$aligner" ]]; then
      shaln_arg_error "shaln align: $flag applies to $OPT_SCOPE bundles, not $aligner"
    fi
    if [[ "$OPT_KIND" == "bool" ]]; then
      out="$out, $OPT_PARAM := true"
      shift
      continue
    fi
    [[ $# -ge 2 ]] || shaln_arg_error "shaln align: '$flag' requires a value"
    value="$2"
    shift 2
    case "$OPT_KIND" in
    uint) shaln_validate_uint "$flag" "$value" ;;
    num) shaln_validate_num "$flag" "$value" ;;
    string) value="$(shaln_sql_quote "$value")" ;;
    esac
    out="$out, $OPT_PARAM := $value"
  done
  printf '%s' "$out"
}

# shaln_align_opt_usage_group <scope> — print one "    --flag <hint>" line per
# option in <scope>, deriving the value hint from the kind. Used by the usage text
# so the documented surface is generated from the same table that parsing uses.
shaln_align_opt_usage_group() {
  local want="$1" cf cp ck cs hint
  while read -r cf cp ck cs; do
    [[ -z "$cf" ]] && continue
    [[ "$cs" == "$want" ]] || continue
    case "$ck" in
    uint) hint=" N" ;;
    num) hint=" FLOAT" ;;
    string) hint=" STR" ;;
    *) hint="" ;;
    esac
    printf '    %s%s\n' "$cf" "$hint"
  done <<EOF
$(shaln_align_opt_table)
EOF
}

# shaln_align_passthrough_usage — the alignment passthrough block of the usage
# text, grouped by aligner scope (generated from shaln_align_opt_table).
shaln_align_passthrough_usage() {
  printf '  Both aligners:\n'
  shaln_align_opt_usage_group both
  printf '  minimap2 bundles only:\n'
  shaln_align_opt_usage_group minimap2
  printf '  bowtie2 bundles only:\n'
  shaln_align_opt_usage_group bowtie2
}

# shaln_infer_format <output-path> — infer the output format from the path's
# extension, recognising the compound/compressed ones (.sam.gz, .pq). Defaults to
# 'sam' (also for an empty path / stdout). Pure; no I/O.
shaln_infer_format() {
  case "$1" in
  *.sam.gz | *.sam.bgz | *.sam) printf 'sam' ;;
  *.bam) printf 'bam' ;;
  *.parquet | *.pq) printf 'parquet' ;;
  *.arrow) printf 'arrow' ;;
  *) printf 'sam' ;;
  esac
}

# shaln_infer_sam_compress <output-path> — for SAM output with no explicit
# --compress, infer 'gzip' from a .gz/.bgz path, else 'none'. Pure; no I/O.
shaln_infer_sam_compress() {
  case "$1" in
  *.gz | *.bgz) printf 'gzip' ;;
  *) printf 'none' ;;
  esac
}

shaln_align_usage() {
  cat <<EOF
Usage: shaln align --bundle <dir> <reads-input> [options]

Align reads against a bundle built by 'shaln index'. The aligner (minimap2 or
bowtie2) is read from the bundle's manifest.

Reads input (choose one; '-' means stdin):
  --fasta PATH | --fastq PATH   Single-end FASTA/FASTQ (read_fastx auto-detects).
  -1 PATH -2 PATH               Paired-end (two files).
  --interleaved PATH            Interleaved paired-end (R1,R2,R1,R2,...).
  --parquet PATH                Parquet (read_fastx schema).
  --arrow PATH                  Arrow IPC stream ('--arrow -' for stdin).

Required:
  --bundle DIR                  Bundle directory from 'shaln index'.

Output:
  -o, --output PATH             Output file ('-' or omit = stdout). Parquet needs a file.
  --format sam|bam|parquet|arrow  Default: inferred from -o extension (incl. .sam.gz,
                                .pq), else 'sam'.
  --compress gzip|none          SAM only: gzip-compress (BGZF) the SAM. Default: gzip
                                if -o ends in .gz, else none. (BAM is always BGZF;
                                Parquet is always zstd.)
  --include-seq-qual            Write SEQ/QUAL into SAM/BAM (default: '*').
  --recover-names               Emit each read's ORIGINAL name as the QNAME. Default:
                                OFF — the QNAME is the integer 'sequence_index' (the
                                routing key), so alignment streams with no name-join.
                                Recovery adds a read-scale join (see the note below);
                                turn it on only when you need names inline.

Routing:
  (default)                     rype routing index in the bundle.
  --broadcast                   Align every read against every shard.
  --route-threshold FLOAT       rype classification threshold.

Streaming (default: reads are normalized to a temp zstd Parquet in TMPDIR and
streamed input->output; no whole-input table is held in RAM):
  --in-memory                   Hold reads + routing in RAM tables instead (fast
                                path for inputs that fit; skips the Parquet round-trip).
  --reads-cache PATH            Persist the normalized reads Parquet at PATH instead
                                of an auto-deleted temp file (reuse across runs).
  --save-routing PATH           Write the read->shard map (Parquet, zstd) to PATH.
                                Keyed by sequence_index (not the read name).

Alignment passthrough (only options valid for the bundle's aligner are accepted):
$(shaln_align_passthrough_usage)
  --threads N                   DuckDB thread count (SET threads, both aligners).

  --extension-path PATH         Load a local (unsigned) miint extension.
  --verbose                     Timestamped milestones + live per-shard progress (stderr).
  -h, --help                    Show this help.

Note: minimap2 k/w are baked into the .mmi at index time and are not settable here.
Only mapped alignment records are written (per-shard non-matches are dropped). With
rype routing, a read that matches no shard above the threshold is not aligned and
produces no record; --broadcast aligns every read against every shard. --verbose
reports reads-loaded vs classified so this pre-filtering is visible.

QNAMEs: by default the output QNAME is the integer sequence_index, which keeps
alignment fully streaming (no per-read name lookup). To map those integers back to
read names afterwards, join on sequence_index against the reads (keep them with
--reads-cache PATH, whose Parquet has sequence_index + read_id). Pass --recover-names
to write the original names inline instead — at the cost of a read-scale join.
EOF
}

shaln_cmd_align() {
  # --help short-circuits before any input/bundle validation.
  local a
  for a in "$@"; do
    case "$a" in -h | --help)
      shaln_align_usage
      return 0
      ;;
    esac
  done

  # Stage 1: pull the reads input mode out; everything else lands in SHALN_REST.
  shaln_parse_reads_input "$@" || return $?

  # Stage 2: parse the remaining (non-input) flags. shaln's own control flags are
  # handled explicitly; any other --flag is matched against the alignment option
  # table and collected (with its value) into PASS_ARGS for scope-checking +
  # validation once the aligner is known.
  local bundle="" output="" format="" compress="" incl_sq="" broadcast="" threshold="" threads="" ext_path=""
  local in_memory="" reads_cache="" save_routing="" recover_names=""
  local PASS_ARGS=()
  if [[ ${#SHALN_REST[@]} -gt 0 ]]; then set -- "${SHALN_REST[@]}"; else set --; fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --bundle) bundle="${2:-}"; shift 2 ;;
    -o | --output) output="${2:-}"; shift 2 ;;
    --format) format="${2:-}"; shift 2 ;;
    --compress) compress="${2:-}"; shift 2 ;;
    --include-seq-qual) incl_sq=1; shift ;;
    --broadcast) broadcast=1; shift ;;
    --route-threshold) threshold="${2:-}"; shift 2 ;;
    --threads) threads="${2:-}"; shift 2 ;;
    --in-memory) in_memory=1; shift ;;
    --reads-cache) reads_cache="${2:-}"; shift 2 ;;
    --save-routing) save_routing="${2:-}"; shift 2 ;;
    --recover-names) recover_names=1; shift ;;
    --extension-path) ext_path="${2:-}"; shift 2 ;;
    --verbose) SHALN_VERBOSE=1; shift ;;
    -*)
      # Possibly an alignment passthrough option (table-driven). Collect it here;
      # scope/value validation happens in shaln_build_align_params once we know
      # the bundle's aligner.
      if shaln_align_opt_lookup "$1"; then
        if [[ "$OPT_KIND" == "bool" ]]; then
          PASS_ARGS+=("$1")
          shift
        else
          [[ $# -ge 2 ]] || shaln_arg_error "shaln align: '$1' requires a value"
          PASS_ARGS+=("$1" "$2")
          shift 2
        fi
      else
        shaln_arg_error "shaln align: unknown option '$1'"
      fi
      ;;
    *) shaln_arg_error "shaln align: unexpected argument '$1'" ;;
    esac
  done

  # Required bundle + its manifest.
  [[ -n "$bundle" ]] || shaln_arg_error "shaln align: --bundle is required"
  [[ -d "$bundle" ]] || shaln_arg_error "shaln align: bundle directory not found: $bundle"
  [[ -f "$bundle/manifest.tsv" ]] || shaln_arg_error "shaln align: '$bundle' is not a shaln bundle (no manifest.tsv)"

  # Reads input file must exist (unless it is stdin).
  if [[ "$READS_P1" != "/dev/stdin" && ! -f "$READS_P1" ]]; then
    shaln_arg_error "shaln align: reads file not found: $READS_P1"
  fi
  if [[ "$READS_MODE" == "paired" && "$READS_P2" != "/dev/stdin" && ! -f "$READS_P2" ]]; then
    shaln_arg_error "shaln align: mate file not found: $READS_P2"
  fi

  # Numeric validation for shaln's own control flags (interpolated into SQL).
  # Alignment passthrough values are validated in shaln_build_align_params below.
  [[ -n "$threads" ]] && shaln_validate_uint "--threads" "$threads"
  [[ -n "$threshold" ]] && shaln_validate_num "--route-threshold" "$threshold"

  # Aligner comes from the manifest (the bundle was built for exactly one).
  local aligner
  aligner="$(shaln_manifest_get "$bundle" aligner)"
  case "$aligner" in
  minimap2 | bowtie2) ;;
  *) shaln_die "shaln align: bundle manifest has an unknown aligner '$aligner'" ;;
  esac

  # rype/lengths filenames from the manifest. Check non-empty here (not inside a
  # command substitution, where shaln_die's exit would only kill the subshell) so
  # a hand-corrupted manifest fails loud instead of resolving to '$bundle/'.
  local rype_name lengths_name rype_rel lengths_rel
  rype_name="$(shaln_manifest_get "$bundle" rype)"
  lengths_name="$(shaln_manifest_get "$bundle" lengths)"
  [[ -n "$rype_name" ]] || shaln_die "shaln align: bundle manifest '$bundle/manifest.tsv' is missing the 'rype' key"
  [[ -n "$lengths_name" ]] || shaln_die "shaln align: bundle manifest '$bundle/manifest.tsv' is missing the 'lengths' key"
  rype_rel="$bundle/$rype_name"
  lengths_rel="$bundle/$lengths_name"

  # Output format + destination.
  local dest="/dev/stdout"
  [[ -n "$output" && "$output" != "-" ]] && dest="$output"
  [[ -z "$format" ]] && format="$(shaln_infer_format "$output")"
  case "$format" in
  sam | bam | parquet | arrow) ;;
  *) shaln_arg_error "shaln align: --format must be sam, bam, parquet, or arrow (got '$format')" ;;
  esac
  if [[ "$format" == "parquet" && "$dest" == "/dev/stdout" ]]; then
    shaln_arg_error "shaln align: parquet output requires -o <file>"
  fi
  # SAM compression: an explicit --compress (gzip|none) overrides; otherwise infer
  # gzip from a .gz/.bgz output path. Only SAM is user-controllable (BAM is always
  # BGZF, Parquet is always zstd), so --compress on any other format is an error.
  if [[ -n "$compress" ]]; then
    case "$compress" in
    gzip | none) ;;
    *) shaln_arg_error "shaln align: --compress must be 'gzip' or 'none', got '$compress'" ;;
    esac
    [[ "$format" == "sam" ]] || shaln_arg_error "shaln align: --compress applies to SAM output only (BAM is always BGZF, Parquet is always zstd)"
  elif [[ "$format" == "sam" ]]; then
    compress="$(shaln_infer_sam_compress "$output")"
  fi

  # --in-memory holds reads in RAM; --reads-cache persists the on-disk conversion.
  # They are mutually exclusive.
  if [[ -n "$in_memory" && -n "$reads_cache" ]]; then
    shaln_arg_error "shaln align: --in-memory and --reads-cache are mutually exclusive"
  fi

  [[ -n "$ext_path" ]] && SHALN_EXTENSION_PATH="$ext_path"
  SHALN_DUCKDB_BIN="$(shaln_require_duckdb)" || exit 1
  SHALN_DUCKDB_FLAGS="$(shaln_duckdb_flags)"
  [[ "$aligner" == "bowtie2" ]] && shaln_require_bowtie2 align

  # Parquet reads input is used directly (no conversion). It cannot come from
  # stdin (parquet needs a seekable file); fail loud rather than emit a cryptic
  # error. Use --fasta/--fastq/--arrow for stdin instead.
  if [[ "$READS_MODE" == "parquet" ]]; then
    [[ "$READS_P1" == "/dev/stdin" ]] && shaln_arg_error "shaln align: --parquet cannot read from stdin (parquet needs a seekable file). Pass a file path, or use --fasta/--fastq/--arrow for stdin."
    # Verify it already carries the unique BIGINT sequence_index that routing +
    # name recovery key on.
    shaln_verify_reads_parquet "$READS_P1"
  fi

  # Need the arrow extension for Arrow input or Arrow output.
  local needs_arrow=""
  [[ "$READS_MODE" == "arrow" || "$format" == "arrow" ]] && needs_arrow=1

  local routing="rype"
  [[ -n "$broadcast" ]] && routing="broadcast"

  shaln_log "aligning against bundle '$bundle' (aligner=$aligner, routing=$routing, output=$format -> $dest)"

  # --- assemble the SQL -----------------------------------------------------
  local reads_rel sql
  reads_rel="$(shaln_reads_relation "$READS_MODE" "$READS_P1" "$READS_P2")" || exit 1

  sql="$(shaln_extension_preamble)"$'\n'
  [[ -n "$needs_arrow" ]] && sql="${sql}INSTALL arrow FROM community;"$'\n'"LOAD arrow;"$'\n'
  [[ -n "$threads" ]] && sql="${sql}SET threads = ${threads};"$'\n'

  # Reads source __shaln_src (sequence_index, read_id, sequence1, sequence2, qual1,
  # qual2). Streaming default: non-parquet input is converted ONCE to a zstd
  # parquet (re-scanned cheaply per shard from disk, never held whole in RAM) and
  # exposed as a view; parquet input is viewed directly. --in-memory instead holds
  # it as a RAM table (fast path for inputs that fit).
  if [[ -n "$in_memory" ]]; then
    sql="${sql}CREATE OR REPLACE TABLE __shaln_src AS ${reads_rel};"$'\n'
  elif [[ "$READS_MODE" == "parquet" ]]; then
    sql="${sql}CREATE OR REPLACE VIEW __shaln_src AS ${reads_rel};"$'\n'
  else
    local reads_pq
    if [[ -n "$reads_cache" ]]; then
      reads_pq="$reads_cache"
    else
      reads_pq="$(mktemp "${TMPDIR:-/tmp}/shaln-reads.XXXXXX")"
      shaln_tmp_register "$reads_pq"
    fi
    shaln_log "normalizing reads to parquet (zstd) at '${reads_pq}'"
    sql="${sql}COPY (${reads_rel}) TO $(shaln_sql_quote "$reads_pq") (FORMAT PARQUET, COMPRESSION 'zstd');"$'\n'
    sql="${sql}CREATE OR REPLACE VIEW __shaln_src AS SELECT * FROM read_parquet($(shaln_sql_quote "$reads_pq"));"$'\n'
  fi
  # __shaln_query: the BIGINT-keyed align/rype input (sequence_index AS read_id).
  # __shaln_reads: keyed to match the alignment OUTPUT read_id so SEQUENCE_DATA
  # (--include-seq-qual) lines up — by sequence_index by default, by the original
  # read name only under --recover-names. (Also used for the verbose read count,
  # which is key-independent.)
  sql="${sql}CREATE OR REPLACE VIEW __shaln_query AS SELECT sequence_index AS read_id, sequence1, sequence2 FROM __shaln_src;"$'\n'
  if [[ -n "$recover_names" ]]; then
    sql="${sql}CREATE OR REPLACE VIEW __shaln_reads AS SELECT read_id, sequence1, sequence2, qual1, qual2 FROM __shaln_src;"$'\n'
  else
    # SEQUENCE_DATA requires a VARCHAR key; cast the BIGINT sequence_index so the
    # default (no-recovery) --include-seq-qual path matches the stringified QNAME.
    sql="${sql}CREATE OR REPLACE VIEW __shaln_reads AS SELECT sequence_index::VARCHAR AS read_id, sequence1, sequence2, qual1, qual2 FROM __shaln_src;"$'\n'
  fi

  # Routing: __shaln_r2s maps the BIGINT key to shard. Streaming default
  # materializes it to a zstd parquet + view (per-shard re-scans hit disk);
  # --in-memory holds a RAM table; --save-routing persists the map (keyed by
  # sequence_index, not the read name).
  local r2s_select
  if [[ "$routing" == "broadcast" ]]; then
    local shard_values="" s
    while IFS= read -r s; do
      [[ -z "$s" ]] && continue
      [[ -n "$shard_values" ]] && shard_values="$shard_values, "
      shard_values="$shard_values($(shaln_sql_quote "$s"))"
    done <<EOF
$(shaln_manifest_shards "$bundle")
EOF
    [[ -n "$shard_values" ]] || shaln_die "shaln align: bundle manifest lists no shards"
    r2s_select="SELECT r.read_id, s.shard_name FROM __shaln_query r CROSS JOIN (VALUES ${shard_values}) s(shard_name)"
  else
    [[ -d "$rype_rel" ]] || shaln_die "shaln align: bundle is missing its rype index '$rype_rel' (use --broadcast to skip routing)"
    local thr_param=""
    [[ -n "$threshold" ]] && thr_param=", threshold := ${threshold}"
    # No DISTINCT: rype_classify emits one row per (read, bucket) (verified). A
    # DISTINCT would add a blocking hash-aggregate that defeats streaming.
    r2s_select="SELECT read_id, bucket_name AS shard_name FROM rype_classify($(shaln_sql_quote "$rype_rel"), '__shaln_query', id_column := 'read_id'${thr_param})"
  fi
  if [[ -n "$in_memory" ]]; then
    sql="${sql}CREATE OR REPLACE TABLE __shaln_r2s AS ${r2s_select};"$'\n'
    [[ -n "$save_routing" ]] && sql="${sql}COPY __shaln_r2s TO $(shaln_sql_quote "$save_routing") (FORMAT PARQUET, COMPRESSION 'zstd');"$'\n'
  else
    local r2s_pq
    if [[ -n "$save_routing" ]]; then
      r2s_pq="$save_routing"
    else
      r2s_pq="$(mktemp "${TMPDIR:-/tmp}/shaln-r2s.XXXXXX")"
      shaln_tmp_register "$r2s_pq"
    fi
    sql="${sql}COPY (${r2s_select}) TO $(shaln_sql_quote "$r2s_pq") (FORMAT PARQUET, COMPRESSION 'zstd');"$'\n'
    sql="${sql}CREATE OR REPLACE VIEW __shaln_r2s AS SELECT * FROM read_parquet($(shaln_sql_quote "$r2s_pq"));"$'\n'
  fi

  local fn="align_minimap2_sharded"
  [[ "$aligner" == "bowtie2" ]] && fn="align_bowtie2_sharded"
  local params="" prog=""
  if [[ ${#PASS_ARGS[@]} -gt 0 ]]; then
    params="$(shaln_build_align_params "$aligner" "${PASS_ARGS[@]}")" || exit $?
  fi
  [[ -n "${SHALN_VERBOSE:-}" ]] && prog=", progress := true"

  # Verbose Layer-1 stats: cheap scans of the reads/routing relations. No
  # alignment pre-count (that needed a full __shaln_aln materialization) — Layer-2
  # progress (progress := true) already streams per-shard alignment counts live.
  local stats=""
  if [[ -n "${SHALN_VERBOSE:-}" ]]; then
    stats="$(mktemp "${TMPDIR:-/tmp}/shaln-stats.XXXXXX")"
    shaln_tmp_register "$stats"
    sql="${sql}COPY (SELECT 'summary' AS a, 'reads' AS b, (SELECT count(*) FROM __shaln_reads)::VARCHAR AS c UNION ALL SELECT 'summary', 'classified', (SELECT count(*) FROM __shaln_r2s)::VARCHAR UNION ALL SELECT 'shard', shard_name, count(*)::VARCHAR FROM __shaln_r2s GROUP BY shard_name) TO $(shaln_sql_quote "$stats") (FORMAT csv, HEADER false);"$'\n'
  fi

  # Stream alignment straight into the output COPY — no __shaln_aln table.
  #
  # By default the output read_id (QNAME) is the BIGINT sequence_index — the cheap
  # routing key — so alignment streams with NO extra join. With --recover-names we
  # join the BIGINT-keyed output back to __shaln_src on sequence_index to restore
  # the original read name; that join's build side (ids+names for every read) is
  # read-scale (it spills to disk rather than OOMs, but it is not constant-memory),
  # which is exactly why recovery is opt-in.
  local align_call recovered destq
  align_call="${fn}('__shaln_query', shard_directory := $(shaln_sql_quote "$bundle"), read_to_shard := '__shaln_r2s'${params}${prog})"
  if [[ -n "$recover_names" ]]; then
    recovered="SELECT nm.read_id AS read_id, aln.* EXCLUDE (read_id) FROM ${align_call} aln JOIN (SELECT sequence_index, read_id FROM __shaln_src) nm ON aln.read_id = nm.sequence_index WHERE NOT alignment_is_unmapped(aln.flags)"
  else
    recovered="SELECT * FROM ${align_call} aln WHERE NOT alignment_is_unmapped(aln.flags)"
  fi
  destq="$(shaln_sql_quote "$dest")"
  case "$format" in
  sam | bam)
    local fmtkw="SAM" comp=""
    [[ "$format" == "bam" ]] && fmtkw="BAM"
    # SAM compression is explicit (gzip|none) so it never depends on the dest
    # extension's auto-detect; BAM ignores it (always BGZF).
    if [[ "$format" == "sam" ]]; then
      [[ "$compress" == "gzip" ]] && comp=", COMPRESSION gzip"
      [[ "$compress" == "none" ]] && comp=", COMPRESSION none"
    fi
    local seqdata=""
    [[ -n "$incl_sq" ]] && seqdata=", SEQUENCE_DATA '__shaln_reads'"
    sql="${sql}CREATE OR REPLACE VIEW __shaln_lengths AS SELECT * FROM read_parquet($(shaln_sql_quote "$lengths_rel"));"$'\n'
    sql="${sql}COPY (${recovered}) TO ${destq} (FORMAT ${fmtkw}, REFERENCE_LENGTHS '__shaln_lengths'${seqdata}${comp});"$'\n'
    ;;
  parquet)
    sql="${sql}COPY (${recovered}) TO ${destq} (FORMAT PARQUET, COMPRESSION 'zstd');"$'\n'
    ;;
  arrow)
    # The arrow writer cannot consume the streamed alignment output directly — a
    # pre-existing arrow-extension bug surfaces as "Expected first offset >= 0"
    # / an assertion abort on the alignment function's string_view columns. Stage
    # through a temp parquet (flat vectors dodge it): no output-scale RAM table,
    # and the temp file is auto-cleaned. (COPY-to-file writes nothing to stdout in
    # -batch, so the arrow stream on /dev/stdout stays clean.)
    local aln_pq
    aln_pq="$(mktemp "${TMPDIR:-/tmp}/shaln-aln.XXXXXX")"
    shaln_tmp_register "$aln_pq"
    sql="${sql}COPY (${recovered}) TO $(shaln_sql_quote "$aln_pq") (FORMAT PARQUET, COMPRESSION 'zstd');"$'\n'
    sql="${sql}COPY (SELECT * FROM read_parquet($(shaln_sql_quote "$aln_pq"))) TO ${destq} (FORMAT arrow);"$'\n'
    ;;
  esac

  shaln_run_sql_stream "$sql"

  # Layer-1 verbose counts, read back from the stats file.
  if [[ -n "${SHALN_VERBOSE:-}" && -f "$stats" ]]; then
    local tag key val
    while IFS=, read -r tag key val; do
      case "$tag" in
      summary) shaln_log "$key: $val" ;;
      shard) shaln_log "  routed to shard '$key': $val read(s)" ;;
      esac
    done <"$stats"
  fi
  shaln_log "wrote $format alignments to '$dest'"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

shaln_main() {
  set -euo pipefail
  local cmd="${1:-}"
  [[ $# -gt 0 ]] && shift || true
  case "$cmd" in
  index) shaln_cmd_index "$@" ;;
  align) shaln_cmd_align "$@" ;;
  version | --version | -V) shaln_cmd_version ;;
  help | --help | -h) shaln_usage ;;
  "")
    shaln_usage >&2
    exit 2
    ;;
  *)
    shaln_err "unknown subcommand '$cmd'"
    shaln_usage >&2
    exit 2
    ;;
  esac
}

# Only run when executed directly; sourcing (e.g. from tests) just defines functions.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  shaln_main "$@"
fi
